# ShieldX Environment Variables
# Copy this to .env and fill in your values

# Deployer wallet private key (TESTNET ONLY — never use mainnet keys)
# Fund with PAS test tokens from https://faucet.polkadot.io/
PRIVATE_KEY=0x_your_testnet_private_key_here

# Polkadot Hub TestNet RPC (choose one)
# Parity official:
POLKADOT_RPC=https://eth-rpc-testnet.polkadot.io/
# OpsLayer alternative:
# POLKADOT_RPC=https://services.polkadothub-rpc.com/testnet/

# Gas reporting (set to "true" for gas snapshots)
REPORT_GAS=false

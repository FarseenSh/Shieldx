{
  "name": "shieldx-protocol",
  "version": "0.1.0",
  "description": "MEV-Protected Cross-Chain Intent Execution Protocol on Polkadot Hub",
  "scripts": {
    "compile": "hardhat compile",
    "test": "hardhat test",
    "test:unit": "hardhat test test/unit/",
    "test:integration": "hardhat test test/integration/",
    "test:gas": "REPORT_GAS=true hardhat test",
    "deploy:testnet": "hardhat run scripts/deploy.js --network polkadotTestnet",
    "lint:sol": "solhint 'contracts/**/*.sol'",
    "clean": "hardhat clean",
    "frontend:dev": "cd frontend && npm run dev",
    "frontend:build": "cd frontend && npm run build"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
    "@nomicfoundation/hardhat-ethers": "^3.0.0",
    "@nomicfoundation/hardhat-verify": "^2.0.0",
    "@openzeppelin/contracts": "^5.0.0",
    "ethers": "^6.0.0",
    "hardhat": "^2.27.0",
    "solhint": "^5.0.0",
    "dotenv": "^16.0.0"
  },
  "keywords": ["polkadot", "mev", "defi", "batch-auction", "xcm", "pvm"],
  "license": "MIT"
}
